{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install && pip install -r requirements.txt",
  "buildCommand": "npm run build",
  "rewrites": [
    {
      "source": "/api/extract",
      "destination": "/api/main/extract"
    },
    {
      "source": "/api/health",
      "destination": "/api/main/health"
    }
  ]
}
